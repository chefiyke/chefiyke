   entryCount: nat;
   netBalance: int;
   totalExpenses: nat;
   totalIncome: nat;
 };
type FinanceEntry = 
 record {
   amount: nat;
   createdAt: Timestamp;
   date: text;
   description: text;
   entryType: EntryType;
   id: nat;
 };
type EntryType = 
 variant {
   expense;
   income;
 };
type DeploymentEntry = 
 record {
   deployedAt: int;
   note: text;
   version: nat;
 };
type Deliverable = 
 record {
   description: text;
   fileType: opt text;
   id: text;
   isAvailable: bool;
   title: text;
   uploadedAt: Timestamp;
   url: opt text;
 };
type CryptoPaymentPublic = 
 record {
   enabled: bool;
   network: text;
   paymentInstructions: text;
   usdcEnabled: bool;
   usdcWalletAddress: text;
   usdtWalletAddress: text;
 };
type CryptoPaymentConfig = 
 record {
   eligibleOfferIds: vec text;
   enabled: bool;
   network: text;
   paymentInstructions: text;
   usdcEnabled: bool;
   usdcWalletAddress: text;
   usdtWalletAddress: text;
 };
type CreateProjectRequest = 
 record {
   clientEmail: text;
   clientName: text;
   clientPrincipal: principal;
   expectedEndDate: opt Timestamp;
   projectDescription: text;
   projectTitle: text;
   startDate: Timestamp;
   tier: ConsultingTier;
 };
type ContactPlatform = 
 record {
   displayLabel: opt text;
   id: text;
   isVisible: bool;
   order: nat;
   platformKey: text;
   platformName: text;
   url: text;
 };
type ContactMessage = 
 record {
   id: nat;
   messageText: text;
   senderName: text;
   timestamp: int;
 };
type ContactLinks = 
 record {
   email: text;
   facebook: text;
   instagram: text;
   primaryCtaText: text;
   whatsapp: text;
 };
