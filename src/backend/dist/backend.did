 record {
   name: text;
   url: text;
 };
type ContactDetails = 
 record {
   email: opt text;
   facebook: opt text;
   instagram: opt text;
   linkedin: opt text;
   otherLinks: vec ContactLink;
   phone: opt text;
   snapchat: opt text;
   tiktok: opt text;
   updatedAt: Timestamp;
   whatsapp: opt text;
   x: opt text;
 };
type ConsultingTier = 
 variant {
   Advisory;
   BakerySetup;
   BakerySetupAndRecipes;
   BusinessDevelopment;
 };
type ConsultancyService = 
 record {
   currency: text;
   description: text;
   id: text;
   isVisible: bool;
   order: nat;
   price: nat;
   title: text;
 };
type CompetencePricing = 
 record {
   currency: text;
   id: text;
   isVisible: bool;
   order: nat;
   price: nat;
   shortDescription: text;
   title: text;
 };
type CompetenceCard = 
 record {
   description: text;
   isVisible: bool;
   title: text;
 };
type CommissionSettings = 
 record {
   defaultRate: float64;
   overrideRates: vec record {
                        text;
                        float64;
                      };
 };
type ClientProjectStatus = 
 variant {
   Completed;
   InProgress;
   OnHold;
   Pending;
   UnderReview;
 };
type ClientProject = 
 record {
   clientEmail: text;
   clientName: text;
   clientPrincipal: principal;
   completedDate: opt Timestamp;
   createdAt: Timestamp;
   deliverables: vec Deliverable;
   expectedEndDate: opt Timestamp;
   id: text;
   nextSteps: vec NextStep;
   projectDescription: text;
   projectTitle: text;
   startDate: Timestamp;
   status: ClientProjectStatus;
   tier: ConsultingTier;
   updatedAt: Timestamp;
   updates: vec ProjectUpdate;
 };
type BuyerLeadStatus = 
 variant {
   Contacted;
   Converted;
   New;
   Rejected;
 };
type BuyerLead = 
 record {
   assignedTo: opt principal;
   budgetRange: text;
   businessName: text;
   businessType: text;
   createdAt: Timestamp;
   email: text;
   formSource: FormSource;
   id: nat;
   name: text;
   notes: opt text;
   phone: text;
   projectDescription: text;
   status: BuyerLeadStatus;
   timeline: text;
   updatedAt: Timestamp;
 };
type Bundle = 
 record {
   bundlePrice: nat;
   currency: text;
   description: text;
   id: text;
   includedServiceIds: vec text;
   isVisible: bool;
   order: nat;
   title: text;
 };
type BlockEntry = 
 record {
   blockedAt: int;
   key: text;
   reason: text;
 };
type AuditLog = 
 record {
   action: AuditAction;
   details: text;
   ip: opt IpAddress;
   logId: nat;
   resource: text;
   timestamp: Timestamp;
   userId: principal;
   userRole: UserRole;
 };
type AuditAction = 
 variant {
   AccessDenied;
   Approve;
   Create;
   Delete;
   Login;
   Logout;
   Reject;
   Update;
 };
type AffiliateStatus = 
 variant {
   approved;
   disabled;
   pending;
   rejected;
 };
type AffiliateStats = 
 record {
   pendingPayout: float64;
   totalClicks: nat;
   totalCommissionEarned: float64;
   totalConversions: nat;
   totalLeads: nat;
 };
type AffiliateProfile = 
 record {
   email: text;
   inviteCode: text;
   joinedAt: Timestamp;
   name: text;
   "principal": principal;
   referralCode: text;
   rejectionReason: opt text;
   status: AffiliateStatus;
 };
type ActivityLog = 
 record {
   action: text;
   actorId: principal;
   actorRole: UserRole;
   id: text;
   ipAddress: opt IpAddress;
   target: text;
   timestamp: Timestamp;
 };
type AboutSection = 
 record {
   bio: text;
   title: text;
 };
service : {
  _internalCreateLeadFromContact: (name: text, email: text, message: 
   text, affiliateRef: opt text, nowNanos: int) -> () oneway;
  adminAddDeliverable: (projectId: text, deliverable: Deliverable) ->
   (variant {
      err: text;
      ok;
    });
  adminAddFinanceEntry: (entryType: EntryType, amount: nat, description:
   text, date: text) -> ();
  adminAddGalleryImage: (storageId: text, caption: text) ->
   (variant {
      err: text;
      ok;
    });
  adminAddGalleryVideo: (input: GalleryVideoInput) ->
   (variant {
      err: text;
      ok: GalleryVideo;
    });
  adminAddNextStep: (projectId: text, description: text) ->
   (variant {
      err: text;
      ok;
    });
  adminAddOrder: (customerName: text, customerEmail: text, product: text,
   amount: float64, notes: text, customerId: opt principal, assignedStaff:
   opt principal) -> (variant {
                        err: text;
                        ok: text;
                      });
  adminAddPayout: ("record": PayoutRecord) -> (variant {
                                                 err: text;
                                                 ok: text;
                                               });
  adminAddSystemApp: (name: text, description: text, url: text) ->
   (variant {
      err: text;
      ok: SystemApp;
    });
  adminAddUpdate: (projectId: text, title: text, content: text) ->
   (variant {
      err: text;
      ok;
    });
  adminAdjustCommission: (affiliateId: text, amount: float64, reason:
   text) -> (variant {
               err: text;
               ok: text;
             });
  adminApproveAffiliate: (affiliatePrincipal: principal) ->
   (variant {
      err: text;
      ok: text;
    });
  adminApprovePaymentOrder: (orderId: nat, approve: bool, notes: opt text) ->
   (variant {
      err: text;
      ok: text;
    });
  adminBlockKey: (key: text, reason: text) -> ();
  adminCreateLiveSession: (title: text, description: text, date: int,
   joinLink: text) -> ();
  adminCreateProject: (req: CreateProjectRequest) ->
   (variant {
      err: text;
      ok: text;
    });
  adminCreateTrainingModule: (title: text, description: text, videoStorageId:
   opt text, textContent: text, order: nat) -> ();
  adminDeleteFinanceEntry: (id: nat) -> ();
  adminDeleteGalleryImage: (id: nat) -> ();
  adminDeleteGalleryVideo: (id: nat) -> ();
  adminDeleteLiveSession: (id: nat) -> ();
  adminDeleteSystemApp: (id: text) -> (variant {
                                         err: text;
                                         ok: text;
                                       });
  adminDeleteTrainingModule: (id: nat) -> ();
  adminDisableAffiliate: (affiliatePrincipal: principal) ->
   (variant {
      err: text;
      ok: text;
    });
  adminEditGalleryVideo: (id: nat, input: GalleryVideoInput) ->
   (variant {
      err: text;
      ok: GalleryVideo;
    });
  adminEditSystemApp: (id: text, name: text, description: text, url: 
   text) -> (variant {
               err: text;
               ok: text;
             });
  adminGetAffiliateStats: (affiliateId: text) -> (AffiliateStats);
  adminGetAffiliates: () -> (vec AffiliateProfile);
  adminGetAllContactPlatforms: () -> (vec ContactPlatform);
  adminGetAllLegalContent: () -> (vec LegalContent);
  adminGetAllProjects: () -> (variant {
                                err: text;
                                ok: vec ClientProject;
                              });
  adminGetAllTestimonials: () -> (vec Testimonial);
  adminGetBlockedKeys: () -> (vec BlockEntry);
  adminGetBrandTagline: () -> (text);
  adminGetCompetenceCards: () -> (vec CompetenceCard);
  adminGetCompetenceSectionVisible: () -> (bool);
  adminGetContactLinks: () -> (ContactLinks);
  adminGetContactMessages: () -> (vec ContactMessage);
  adminGetCryptoPaymentConfig: () ->
   (variant {
      err: text;
      ok: CryptoPaymentConfig;
    });
  adminGetDeploymentLog: () -> (vec DeploymentEntry);
  adminGetFinanceEntries: () -> (vec FinanceEntry);
  adminGetFinanceSummary: () -> (FinanceSummary);
  adminGetGalleryImages: () -> (vec GalleryImage);
  adminGetGalleryVideos: () -> (vec GalleryVideo);
  adminGetHeroImageIds: () -> (HeroImageIds);
  adminGetLead: (id: text) -> (opt Lead);
  adminGetLeadStats: () -> (LeadStats);
  adminGetLeads: (filter: LeadFilter) -> (vec Lead);
  adminGetOrder: (id: text) -> (opt Order);
