  claimOwnership: (email: text) -> (RoleResult);
  clientGetMyProject: () -> (variant {
                               err: text;
                               ok: ClientProject;
                             });
  confirmOwnership: () -> (record {
                             isOwnerOrAdmin: bool;
                             role: opt UserRole;
                           });
  createPaymentOrder: (payerName: text, payerEmail: text, payerPhone:
   opt text, method: variant {
                       flutterwave;
                       localBank;
                       paystack;
                     }) -> (variant {
                              err: text;
                              ok: PaymentOrder;
                            });
  flutterwaveWebhook: (body: text, signature: text) ->
   (variant {
      err: text;
      ok: text;
    });
  getAbout: () -> (AboutSection) query;
  getActivityLog: (limit: nat) -> (vec ActivityLog);
  getBrandTagline: () -> (text) query;
  getCompetenceCards: () -> (vec CompetenceCard) query;
  getCompetenceCardsVisible: () -> (vec CompetenceCard) query;
  getCompetenceSectionVisible: () -> (bool) query;
  getContactDetails: () -> (ContactDetails) query;
  getContactLinks: () -> (ContactLinks) query;
  getContactPlatforms: () -> (vec ContactPlatform) query;
  getGalleryImages: () -> (vec GalleryImage) query;
  getGalleryVideos: () -> (vec GalleryVideo) query;
  getHelpBlocks: () -> (vec HelpBlock) query;
  getHeroImageIds: () -> (HeroImageIds) query;
  getHeroSlides: () -> (vec HeroSlide) query;
  getLegalContent: (id: text) -> (opt LegalContent) query;
  getLiveSessions: () -> (vec LiveSession) query;
  getMyRole: () -> (opt UserRole);
  getOwnerDebugInfo: () ->
   (record {
      callerEmail: opt text;
      callerIsOwner: bool;
      callerRole: text;
      ownerEmail: text;
    }) query;
  getPaymentConfig: () -> (PaymentConfigPublic) query;
  getPricingData: () -> (PricingData) query;
  getPublicCryptoPaymentInfo: () -> (opt CryptoPaymentPublic) query;
  getSignatureEdge: () -> (SignatureEdge) query;
  getSystemConfig: () -> (SystemConfig) query;
  getSystemsApps: () -> (vec SystemApp) query;
  getTestimonials: () -> (vec Testimonial) query;
  getTrainingModules: () -> (vec TrainingModule);
  getUserRole: (target: principal) -> (opt UserRole);
  getVersionInfo: () -> (VersionInfo) query;
  getVisibleTestimonials: () -> (vec Testimonial) query;
  listUsersByRole: (role: UserRole) -> (vec StaffUser);
  paystackWebhook: (body: text, signature: text) ->
   (variant {
      err: text;
      ok: text;
    });
  revokeUserRole: (target: principal) -> (RoleResult);
  submitBuyerLead: (name: text, email: text, phone: text, businessName: 
   text, businessType: text, projectDescription: text, timeline: text,
   budgetRange: text, formSource: FormSource, honeypot: text) ->
   (variant {
      err: text;
      ok: text;
    });
  submitContactMessage: (senderName: text, messageText: text, honeypot:
   text) -> (SubmitResult);
  trackReferralClick: (affiliateId: text, source: text) -> ();
}
