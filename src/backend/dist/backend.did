type VersionInfo = 
 record {
   buildVersion: nat;
   environment: text;
   lastDeployedAt: int;
   systemVersion: text;
 };
type UserRole = 
 variant {
   Admin;
   Affiliate;
   Customer;
   PlatformOwner;
   Staff;
 };
type UpdateProjectRequest = 
 record {
   completedDate: opt Timestamp;
   expectedEndDate: opt Timestamp;
   projectDescription: opt text;
   projectTitle: opt text;
   status: opt ClientProjectStatus;
 };
type TrainingModule = 
 record {
   createdAt: Timestamp;
   description: text;
   id: nat;
   order: nat;
   textContent: text;
   title: text;
   videoStorageId: opt text;
 };
type Timestamp = int;
type Testimonial = 
 record {
   author: text;
   isVisible: bool;
   role: text;
   "text": text;
 };
type SystemConfig = 
 record {
   brandTagline: text;
   competenceSectionVisible: bool;
   ctaExploreSystems: text;
   ctaGetLandingPage: text;
   ctaViewCompetence: text;
   ctaWorkWithMe: text;
   environment: text;
   footerText: text;
   heroHeadline: text;
   heroSubtext: text;
   maintenanceMode: bool;
   siteDescription: text;
   siteTitle: text;
 };
type SystemApp = 
 record {
   createdAt: int;
   description: text;
   id: text;
   isVisible: bool;
   name: text;
   order: nat;
   url: text;
 };
type SubmitResult = 
 variant {
   err: text;
   ok: text;
 };
type StaffUser = 
 record {
   email: text;
   id: principal;
   invitedAt: Timestamp;
   lastLoginAt: opt Timestamp;
   permissions: vec Permission;
   role: UserRole;
   status: variant {
             active;
             inactive;
             pending;
           };
 };
type SlideButton = 
 record {
   href: text;
   "text": text;
 };
type SignatureEdge = 
 record {
   pillar1: text;
   pillar2: text;
   pillar3: text;
   quote: text;
 };
type SecurityPolicy = 
 record {
   lockoutDurationMins: nat;
   maxLoginAttempts: nat;
   rateLimitPerMin: nat;
   rateLimitPublicPerMin: nat;
   sessionTimeoutMins: nat;
 };
type SalesStats = 
 record {
   pendingPayments: nat;
   totalOrders: nat;
   totalRevenue: float64;
 };
type SalesFilter = 
 record {
   assignedStaff: opt principal;
   fromDate: opt Timestamp;
   product: opt text;
   status: opt OrderStatus;
   toDate: opt Timestamp;
 };
type RoleResult = 
 variant {
   err: text;
   ok: text;
 };
type ProjectUpdate = 
 record {
   content: text;
   createdAt: Timestamp;
   id: text;
   isPublished: bool;
   title: text;
 };
type PricingData = 
 record {
   bundles: vec Bundle;
   competencePricing: vec CompetencePricing;
   consultancyServices: vec ConsultancyService;
   giveaways: vec GiveawayItem;
   landingPageOffers: vec LandingPageOffer;
 };
type Permission = 
 variant {
   CanEditContactDetails;
   CanEditContent;
   CanManageAffiliates;
   CanManageBuyerLeads;
   CanManageFinance;
   CanManageLeads;
   CanManageMedia;
   CanManagePayments;
   CanManageRoles;
   CanManageSales;
   CanManageSecurity;
   CanManageStaff;
   CanManageTraining;
   CanViewAuditLog;
   CanViewDashboard;
   CanViewReports;
 };
type PaystackConfig = 
 record {
   publicKey: text;
   secretKey: text;
   webhookSecret: text;
 };
type PayoutStatus = 
 variant {
   completed;
   pending;
 };
type PayoutRecord = 
 record {
   adjustedBy: opt principal;
   adjustmentNote: text;
   affiliateId: text;
   amount: float64;
   id: text;
   method: text;
   processedAt: opt Timestamp;
   requestedAt: Timestamp;
   status: PayoutStatus;
 };
type PaymentOrderStatus = 
 variant {
   Completed;
   Failed;
   Pending;
   Rejected;
 };
type PaymentOrder = 
 record {
   amount: nat;
   approvedBy: opt principal;
   createdAt: Timestamp;
   currency: text;
   method: variant {
             flutterwave;
             localBank;
             paystack;
           };
   notes: opt text;
   orderId: nat;
   payerEmail: text;
   payerName: text;
   payerPhone: opt text;
   status: PaymentOrderStatus;
   updatedAt: Timestamp;
   webhookRef: opt text;
 };
type PaymentConfigPublic = 
 record {
   defaultCurrency: text;
   enabledMethods: vec variant {
                         flutterwave;
                         localBank;
                         paystack;
                       };
   flutterwavePublicKey: opt text;
   localBank: opt LocalBankConfig;
   paystackPublicKey: opt text;
   servicePriceNgn: nat;
 };
type PaymentConfig = 
 record {
   defaultCurrency: text;
   enabledMethods: vec variant {
                         flutterwave;
                         localBank;
                         paystack;
                       };
   flutterwave: opt FlutterwaveConfig;
   localBank: opt LocalBankConfig;
   paystack: opt PaystackConfig;
   servicePriceNgn: nat;
   updatedAt: Timestamp;
 };
type OrderStatus = 
 variant {
   completed;
   failed;
   pending;
   refunded;
 };
type Order = 
 record {
   amount: float64;
   assignedStaff: opt principal;
   createdAt: Timestamp;
   customerEmail: text;
   customerId: opt principal;
   customerName: text;
   id: text;
   notes: text;
   product: text;
   status: OrderStatus;
   updatedAt: Timestamp;
 };
