   email: text;
   id: text;
   message: text;
   name: text;
   notes: text;
   phone: opt text;
   source: LeadSource;
   status: LeadStatus;
   updatedAt: Timestamp;
 };
type LandingPageOffer = 
 record {
   currency: text;
   description: text;
   id: text;
   isVisible: bool;
   price: nat;
