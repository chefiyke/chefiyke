   createdAt: Timestamp;
   date: Timestamp;
   description: text;
   id: nat;
   joinLink: text;
   title: text;
 };
type LegalContent = 
 record {
   content: text;
   id: text;
   lastUpdated: int;
   title: text;
 };
type LeadStatus = 
 variant {
   contacted;
   converted;
   new;
   qualified;
   rejected;
 };
type LeadStats = 
 record {
   newLeads: nat;
   qualifiedLeads: nat;
   totalLeads: nat;
 };
type LeadSource = 
