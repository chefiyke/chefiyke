   aboutImageId: opt text;
   presenceImageId: opt text;
   slide1ImageId: opt text;
   slide2ImageId: opt text;
   slide3ImageId: opt text;
 };
type HelpBlock = 
 record {
   description: text;
   title: text;
 };
type GiveawayItem = 
